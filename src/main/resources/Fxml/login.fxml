<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane fx:id="loginFrame" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="520.0" prefWidth="760.0" stylesheets="@../Styles/login.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.repit.Controllers.loginController">
   <children>
      <HBox alignment="CENTER" spacing="24.0" AnchorPane.bottomAnchor="24.0" AnchorPane.leftAnchor="24.0" AnchorPane.rightAnchor="24.0" AnchorPane.topAnchor="24.0">
         <children>
            <AnchorPane prefHeight="472.0" prefWidth="300.0" styleClass="auth-media-card">
               <children>
                  <ImageView fitHeight="472.0" fitWidth="300.0" pickOnBounds="true" preserveRatio="false" styleClass="auth-image" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                     <image>
                        <Image url="@../Images/repitLogin.jpeg" />
                     </image>
                  </ImageView>
                  <VBox spacing="10.0" styleClass="auth-media-copy" AnchorPane.bottomAnchor="24.0" AnchorPane.leftAnchor="24.0" AnchorPane.rightAnchor="24.0">
                     <children>
                        <Label styleClass="section-title" text="Train with focus" />
                        <Label text="Log in and continue your current workout plan without extra clutter." wrapText="true" />
                     </children>
                  </VBox>
               </children>
            </AnchorPane>
            <VBox fx:id="loginPane" prefHeight="472.0" prefWidth="360.0" styleClass="auth-card">
               <children>
                  <VBox spacing="8.0">
                     <children>
                        <Text fx:id="loginPaneTitleText" strokeType="OUTSIDE" strokeWidth="0.0" styleClass="auth-title" text="Login" />
                        <Label text="Use your RepIt account to access your schedule, videos, and workout tracking." wrapText="true" />
                     </children>
                  </VBox>
                  <Region prefHeight="8.0" />
                  <Label styleClass="field-label" text="Username" />
                  <TextField fx:id="username" promptText="Username" />
                  <Label styleClass="field-label" text="Password" />
                  <PasswordField fx:id="password" promptText="Password" />
                  <Label fx:id="label" text="" wrapText="true" />
                  <Region prefHeight="11.0" prefWidth="310.0" VBox.vgrow="ALWAYS" />
                  <Button fx:id="button" defaultButton="true" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#userLogin" prefHeight="40.0" text="Login" />
                  <Hyperlink fx:id="loginPaneLinker" onAction="#createAccountLinkerClicked" text="Create an account" />
               </children>
            </VBox>
         </children>
      </HBox>
   </children>
</AnchorPane>
