<AnchorPane prefHeight="640.0" prefWidth="900.0" styleClass="screen setup-screen" stylesheets="@../../Styles/setup.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.repit.Controllers.Client.setupController">
   <children>
      <VBox spacing="18.0" styleClass="screen-shell" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
         <children>
            <VBox spacing="6.0">
               <children>
                  <Text strokeType="OUTSIDE" strokeWidth="0.0" styleClass="screen-title" text="Complete Your Setup" />
                  <Label text="Choose the days you can train, how much time you have on each day, and what result you want from the plan." wrapText="true" />
               </children>
            </VBox>
            <HBox spacing="18.0" VBox.vgrow="ALWAYS">
               <children>
                  <VBox spacing="14.0" styleClass="panel-card" HBox.hgrow="ALWAYS">
                     <children>
                        <Label styleClass="section-title" text="Available Time" />
                        <GridPane hgap="16.0" styleClass="schedule-grid" vgap="10.0">
                           <columnConstraints>
                              <ColumnConstraints hgrow="NEVER" minWidth="110.0" prefWidth="130.0" />
                              <ColumnConstraints hgrow="ALWAYS" minWidth="140.0" prefWidth="180.0" />
                           </columnConstraints>
                           <children>
                              <CheckBox fx:id="mondayCheckBox" mnemonicParsing="false" text="Monday" GridPane.rowIndex="0" />
                              <ComboBox fx:id="mondayTimeComboBox" prefWidth="180.0" promptText="Duration" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                 <items>
                                    <FXCollections fx:factory="observableArrayList">
                                       <String fx:value="10 minutes" />
                                       <String fx:value="20 minutes" />
                                       <String fx:value="30 minutes" />
                                       <String fx:value="40 minutes" />
                                       <String fx:value="50 minutes" />
                                       <String fx:value="60 minutes" />
                                    </FXCollections>
                                 </items>
                              </ComboBox>
                              <CheckBox fx:id="tuesdayCheckBox" mnemonicParsing="false" text="Tuesday" GridPane.rowIndex="1" />
                              <ComboBox fx:id="tuesdayTimeComboBox" prefWidth="180.0" promptText="Duration" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                 <items>
                                    <FXCollections fx:factory="observableArrayList">
                                       <String fx:value="10 minutes" />
                                       <String fx:value="20 minutes" />
                                       <String fx:value="30 minutes" />
                                       <String fx:value="40 minutes" />
                                       <String fx:value="50 minutes" />
                                       <String fx:value="60 minutes" />
                                    </FXCollections>
                                 </items>
                              </ComboBox>
                              <CheckBox fx:id="wednesdayCheckBox" mnemonicParsing="false" text="Wednesday" GridPane.rowIndex="2" />
                              <ComboBox fx:id="wednesdayTimeComboBox" prefWidth="180.0" promptText="Duration" GridPane.columnIndex="1" GridPane.rowIndex="2">
                                 <items>
                                    <FXCollections fx:factory="observableArrayList">
                                       <String fx:value="10 minutes" />
                                       <String fx:value="20 minutes" />
                                       <String fx:value="30 minutes" />
                                       <String fx:value="40 minutes" />
                                       <String fx:value="50 minutes" />
                                       <String fx:value="60 minutes" />
                                    </FXCollections>
                                 </items>
                              </ComboBox>
                              <CheckBox fx:id="thursdayCheckBox" mnemonicParsing="false" text="Thursday" GridPane.rowIndex="3" />
                              <ComboBox fx:id="thursdayTimeComboBox" prefWidth="180.0" promptText="Duration" GridPane.columnIndex="1" GridPane.rowIndex="3">
                                 <items>
                                    <FXCollections fx:factory="observableArrayList">
                                       <String fx:value="10 minutes" />
                                       <String fx:value="20 minutes" />
                                       <String fx:value="30 minutes" />
                                       <String fx:value="40 minutes" />
                                       <String fx:value="50 minutes" />
                                       <String fx:value="60 minutes" />
                                    </FXCollections>
                                 </items>
                              </ComboBox>
                              <CheckBox fx:id="fridayCheckBox" mnemonicParsing="false" text="Friday" GridPane.rowIndex="4" />
                              <ComboBox fx:id="fridayTimeComboBox" prefWidth="180.0" promptText="Duration" GridPane.columnIndex="1" GridPane.rowIndex="4">
                                 <items>
                                    <FXCollections fx:factory="observableArrayList">
                                       <String fx:value="10 minutes" />
                                       <String fx:value="20 minutes" />
                                       <String fx:value="30 minutes" />
                                       <String fx:value="40 minutes" />
                                       <String fx:value="50 minutes" />
                                       <String fx:value="60 minutes" />
                                    </FXCollections>
                                 </items>
                              </ComboBox>
                              <CheckBox fx:id="saturdayCheckBox" mnemonicParsing="false" text="Saturday" GridPane.rowIndex="5" />
                              <ComboBox fx:id="saturdayTimeComboBox" prefWidth="180.0" promptText="Duration" GridPane.columnIndex="1" GridPane.rowIndex="5">
                                 <items>
                                    <FXCollections fx:factory="observableArrayList">
                                       <String fx:value="10 minutes" />
                                       <String fx:value="20 minutes" />
                                       <String fx:value="30 minutes" />
                                       <String fx:value="40 minutes" />
                                       <String fx:value="50 minutes" />
                                       <String fx:value="60 minutes" />
                                    </FXCollections>
                                 </items>
                              </ComboBox>
                              <CheckBox fx:id="sundayCheckBox" mnemonicParsing="false" text="Sunday" GridPane.rowIndex="6" />
                              <ComboBox fx:id="sundayTimeComboBox" prefWidth="180.0" promptText="Duration" GridPane.columnIndex="1" GridPane.rowIndex="6">
                                 <items>
                                    <FXCollections fx:factory="observableArrayList">
                                       <String fx:value="10 minutes" />
                                       <String fx:value="20 minutes" />
                                       <String fx:value="30 minutes" />
                                       <String fx:value="40 minutes" />
                                       <String fx:value="50 minutes" />
                                       <String fx:value="60 minutes" />
                                    </FXCollections>
                                 </items>
                              </ComboBox>
                           </children>
                           <rowConstraints>
                              <RowConstraints />
                              <RowConstraints />
                              <RowConstraints />
                              <RowConstraints />
                              <RowConstraints />
                              <RowConstraints />
                              <RowConstraints />
                           </rowConstraints>
                        </GridPane>
                     </children>
                  </VBox>
                  <VBox prefWidth="250.0" spacing="18.0">
                     <children>
                        <VBox spacing="12.0" styleClass="panel-card" VBox.vgrow="ALWAYS">
                           <children>
                              <Label styleClass="section-title" text="Fitness Level" />
                              <VBox spacing="8.0">
                                 <children>
                                    <RadioButton fx:id="beginnerLevelRadio" mnemonicParsing="false" selected="true" text="Beginner">
                                       <toggleGroup>
                                          <ToggleGroup fx:id="fitnessLevelToggleGroup" />
                                       </toggleGroup>
                                    </RadioButton>
                                    <RadioButton fx:id="intermediateLevelRadio" mnemonicParsing="false" text="Intermediate" toggleGroup="$fitnessLevelToggleGroup" />
                                    <RadioButton fx:id="proficientLevelRadio" mnemonicParsing="false" text="Proficient" toggleGroup="$fitnessLevelToggleGroup" />
                                 </children>
                              </VBox>
                           </children>
                        </VBox>
                        <VBox spacing="12.0" styleClass="panel-card" VBox.vgrow="ALWAYS">
                           <children>
                              <Label styleClass="section-title" text="Fitness Goal" />
                              <VBox spacing="8.0">
                                 <children>
                                    <RadioButton fx:id="weightLossGoalRadio" mnemonicParsing="false" selected="true" text="Weight Loss">
                                       <toggleGroup>
