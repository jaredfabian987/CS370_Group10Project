            <HBox alignment="CENTER_RIGHT" spacing="12.0">
               <children>
                  <Label maxWidth="1.7976931348623157E308" text="Select at least one day before continuing." HBox.hgrow="ALWAYS" />
                  <Button fx:id="saveSetupButton" mnemonicParsing="false" prefWidth="140.0" text="Save Setup" />
               </children>
            </HBox>
         </children>
