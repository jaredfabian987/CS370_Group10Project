                                    <Label text="Warm-up - 5 min mobility" />
                                    <Label text="Primary Lift - Barbell squat" />
                                    <Label text="Accessories - Split squats, calf raises, plank holds" wrapText="true" />
                                    <Region VBox.vgrow="ALWAYS" />
                                 </children>
                              </VBox>
                              <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" text="Start Workout" />
