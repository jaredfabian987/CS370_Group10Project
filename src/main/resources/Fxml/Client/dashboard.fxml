<AnchorPane prefHeight="640.0" prefWidth="960.0" styleClass="screen dashboard-screen" stylesheets="@../../Styles/dashboard.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.repit.Controllers.Client.dashboardController">
   <children>
      <VBox fillWidth="true" prefHeight="640.0" prefWidth="960.0" spacing="20.0" styleClass="screen-shell" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
